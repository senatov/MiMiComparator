<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
  MiMiComparator — dual-pane comparator UI
  Left panel | center action strip | right panel
  Column headers: Name | Size | Modified
  Iakov Senatov, 2026
-->

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.senatov.MainController"
            prefWidth="1100" prefHeight="1100"
            style="-fx-font-family:'SF Pro Text'; -fx-font-size:14; -fx-font-weight:100;"
            styleClass="root-pane">

    <!-- ═══ TOP: menu + toolbar ═══ -->
    <top>
        <VBox>
            <MenuBar useSystemMenuBar="true">
                <Menu text="File">
                    <MenuItem text="Open Left…"   onAction="#onOpenLeft"  accelerator="Shortcut+L"/>
                    <MenuItem text="Open Right…"  onAction="#onOpenRight" accelerator="Shortcut+R"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Compare"      onAction="#onCompare"   accelerator="Shortcut+D"/>
                    <MenuItem text="Refresh"      onAction="#onRefresh"   accelerator="Shortcut+Shift+R"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Quit"         onAction="#onQuit"      accelerator="Shortcut+Q"/>
                </Menu>
                <Menu text="View">
                    <CheckMenuItem fx:id="showIdenticalCheck" text="Show identical lines"
                                   selected="true" onAction="#onToggleIdentical"/>
                    <CheckMenuItem fx:id="showDirsCheck" text="Directory mode"
                                   selected="false" onAction="#onToggleDirMode"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Expand All"   onAction="#onExpandAll"   accelerator="Shortcut+E"/>
                    <MenuItem text="Collapse All" onAction="#onCollapseAll" accelerator="Shortcut+Shift+E"/>
                </Menu>
                <Menu text="Help">
                    <MenuItem text="About MiMiComparator" onAction="#onAbout"/>
                </Menu>
            </MenuBar>

            <!-- toolbar -->
            <ToolBar fx:id="mainToolBar">
                <Button text="📂 Left"   onAction="#onOpenLeft"/>
                <Button text="Right 📂"  onAction="#onOpenRight"/>
                <Separator orientation="VERTICAL"/>
                <Button fx:id="compareBtn" text="⚡ Compare" onAction="#onCompare"
                        style="-fx-font-weight:bold;"/>
                <Separator orientation="VERTICAL"/>
                <ToggleButton fx:id="syncScrollToggle" text="↕ Sync" selected="true"/>
                <Separator orientation="VERTICAL"/>
                <ToggleButton fx:id="dirModeToggle" text="📁 Dirs" onAction="#onToggleDirMode"/>
                <Separator orientation="VERTICAL"/>
                <Button text="⊞ Expand" onAction="#onExpandAll"/>
                <Button text="⊟ Collapse" onAction="#onCollapseAll"/>
                <Separator orientation="VERTICAL"/>
                <!-- filter -->
                <Label text="Filters:" style="-fx-text-fill:#666;"/>
                <TextField fx:id="filterField" promptText="*.java, *.txt …"
                           prefWidth="180" onAction="#onFilterChanged"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Label fx:id="diffCountLabel" text="diffs: —"
                       style="-fx-text-fill:#8c1a65;"/>
            </ToolBar>
        </VBox>
    </top>

    <!-- ═══ CENTER: left panel | action strip | right panel ═══ -->
    <center>
        <HBox VBox.vgrow="ALWAYS">

            <!-- ── LEFT panel ── -->
            <VBox fx:id="leftPanel" HBox.hgrow="ALWAYS" spacing="0">
                <padding><Insets top="4" right="2" bottom="4" left="4"/></padding>
                <HBox alignment="CENTER_LEFT" spacing="4">
                    <Label text="Left:" style="-fx-font-weight:bold;"/>
                    <TextField fx:id="leftPathField" HBox.hgrow="ALWAYS"
                               promptText="file or directory…" editable="false"/>
                    <Button text="…" onAction="#onOpenLeft" prefWidth="30"/>
                </HBox>
                <!-- column header -->
                <HBox fx:id="leftColumnHeader" spacing="0"
                      style="-fx-background-color:linear-gradient(to bottom,#F8F8F8,#E8E8E8);
                             -fx-border-color:#CCC;-fx-border-width:0 0 1 0;">
                    <padding><Insets top="3" right="4" bottom="3" left="4"/></padding>
                    <Label text="Name" style="-fx-font-weight:bold;-fx-font-size:12;" HBox.hgrow="ALWAYS"
                           maxWidth="1.7976931348623157E308"/>
                    <Label text="Size" style="-fx-font-weight:bold;-fx-font-size:12;-fx-alignment:CENTER_RIGHT;"
                           minWidth="90" prefWidth="90"/>
                    <Label text="Modified" style="-fx-font-weight:bold;-fx-font-size:12;-fx-alignment:CENTER_RIGHT;"
                           minWidth="140" prefWidth="140"/>
                </HBox>
                <ListView fx:id="leftListView" VBox.vgrow="ALWAYS"/>
            </VBox>

            <!-- ── CENTER action strip ── -->
            <VBox fx:id="centerStrip" alignment="CENTER" spacing="8"
                  prefWidth="52" minWidth="40" maxWidth="80"
                  style="-fx-background-color:linear-gradient(to bottom, #e8e8e8, #d0d0d0);
                         -fx-border-color:#bbb; -fx-border-width:0 1 0 1;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.15),4,0,0,1);">
                <padding><Insets top="12" right="4" bottom="12" left="4"/></padding>

                <Button fx:id="copyRightBtn" text="→" onAction="#onCopyToRight"
                        prefWidth="36" prefHeight="28"
                        style="-fx-font-size:16; -fx-font-weight:bold;">
                    <tooltip><Tooltip text="Copy selected to right"/></tooltip>
                </Button>

                <Button fx:id="copyLeftBtn" text="←" onAction="#onCopyToLeft"
                        prefWidth="36" prefHeight="28"
                        style="-fx-font-size:16; -fx-font-weight:bold;">
                    <tooltip><Tooltip text="Copy selected to left"/></tooltip>
                </Button>

                <Separator prefWidth="30"/>

                <Button fx:id="diffBtn" text="≠" onAction="#onShowDiff"
                        prefWidth="36" prefHeight="28"
                        style="-fx-font-size:16; -fx-font-weight:bold; -fx-text-fill:#c00;">
                    <tooltip><Tooltip text="Show differences"/></tooltip>
                </Button>

                <Button fx:id="equalBtn" text="=" onAction="#onShowEqual"
                        prefWidth="36" prefHeight="28"
                        style="-fx-font-size:16; -fx-font-weight:bold; -fx-text-fill:#070;">
                    <tooltip><Tooltip text="Show identical"/></tooltip>
                </Button>

                <Separator prefWidth="30"/>

                <Button fx:id="deleteBtn" text="🗑" onAction="#onDeleteSelected"
                        prefWidth="36" prefHeight="28">
                    <tooltip><Tooltip text="Delete selected"/></tooltip>
                </Button>
            </VBox>

            <!-- ── RIGHT panel ── -->
            <VBox fx:id="rightPanel" HBox.hgrow="ALWAYS" spacing="0">
                <padding><Insets top="4" right="4" bottom="4" left="2"/></padding>
                <HBox alignment="CENTER_LEFT" spacing="4">
                    <Label text="Right:" style="-fx-font-weight:bold;"/>
                    <TextField fx:id="rightPathField" HBox.hgrow="ALWAYS"
                               promptText="file or directory…" editable="false"/>
                    <Button text="…" onAction="#onOpenRight" prefWidth="30"/>
                </HBox>
                <!-- column header -->
                <HBox fx:id="rightColumnHeader" spacing="0"
                      style="-fx-background-color:linear-gradient(to bottom,#F8F8F8,#E8E8E8);
                             -fx-border-color:#CCC;-fx-border-width:0 0 1 0;">
                    <padding><Insets top="3" right="4" bottom="3" left="4"/></padding>
                    <Label text="Name" style="-fx-font-weight:bold;-fx-font-size:12;" HBox.hgrow="ALWAYS"
                           maxWidth="1.7976931348623157E308"/>
                    <Label text="Size" style="-fx-font-weight:bold;-fx-font-size:12;-fx-alignment:CENTER_RIGHT;"
                           minWidth="90" prefWidth="90"/>
                    <Label text="Modified" style="-fx-font-weight:bold;-fx-font-size:12;-fx-alignment:CENTER_RIGHT;"
                           minWidth="140" prefWidth="140"/>
                </HBox>
                <ListView fx:id="rightListView" VBox.vgrow="ALWAYS"/>
            </VBox>

        </HBox>
    </center>

    <!-- ═══ BOTTOM: status bar ═══ -->
    <bottom>
        <HBox spacing="12" alignment="CENTER_LEFT"
              style="-fx-background-color:#f0f0f0; -fx-border-color:#ccc; -fx-border-width:1 0 0 0;">
            <padding><Insets top="4" right="8" bottom="4" left="8"/></padding>
            <Label fx:id="statusLeft"  text="No file loaded" style="-fx-text-fill:#666;"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusCenter" text="" style="-fx-text-fill:#333; -fx-font-weight:bold;"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusRight" text="No file loaded" style="-fx-text-fill:#666;"/>
        </HBox>
    </bottom>

</BorderPane>
