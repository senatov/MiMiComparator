<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckMenuItem?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<!--
  MiMiComparator — dual-pane comparator UI
  Left panel | center action strip | right panel
  Column headers: Name | Size | Modified
  Iakov Senatov, 2026
-->

<BorderPane prefHeight="1100"
            prefWidth="1100"
            style="-fx-font-family:'SF Pro Text'; -fx-font-size:14; -fx-font-weight:100;"
            styleClass="root-pane"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.senatov.MainController"
>

    <!-- ═══ TOP: menu + toolbar ═══ -->
    <top>
        <VBox>
            <MenuBar useSystemMenuBar="true">
                <Menu text="File">
                    <MenuItem accelerator="Shortcut+L" onAction="#onOpenLeft" text="Open Left…" />
                    <MenuItem accelerator="Shortcut+R" onAction="#onOpenRight" text="Open Right…" />
                    <SeparatorMenuItem />
                    <MenuItem accelerator="Shortcut+D" onAction="#onCompare" text="Compare" />
                    <MenuItem accelerator="Shortcut+Shift+R" onAction="#onRefresh" text="Refresh" />
                    <SeparatorMenuItem />
                    <MenuItem accelerator="Shortcut+Q" onAction="#onQuit" text="Quit" />
                </Menu>
                <Menu text="View">
                    <CheckMenuItem fx:id="showIdenticalCheck" onAction="#onToggleIdentical" selected="true" text="Show identical lines" />
                    <CheckMenuItem fx:id="showDirsCheck" onAction="#onToggleDirMode" selected="false" text="Directory mode" />
                    <SeparatorMenuItem />
                    <MenuItem accelerator="Shortcut+E" onAction="#onExpandAll" text="Expand All" />
                    <MenuItem accelerator="Shortcut+Shift+E" onAction="#onCollapseAll" text="Collapse All" />
                </Menu>
                <Menu text="Help">
                    <MenuItem onAction="#onAbout" text="About MiMiComparator" />
                </Menu>
            </MenuBar>

            <!-- toolbar -->
            <ToolBar fx:id="mainToolBar">
                <ToggleButton fx:id="syncScrollToggle" selected="true" text="↕ Sync" />
                <Separator orientation="VERTICAL" />
                <Button onAction="#onExpandAll" text="⊞ Expand" />
                <Button onAction="#onCollapseAll" text="⊟ Collapse" />
                <Separator orientation="VERTICAL" />
                <Pane HBox.hgrow="ALWAYS">
               <children>
                      <TextField fx:id="filterField" layoutX="411.0" layoutY="4.0" onAction="#onFilterChanged" prefWidth="180" promptText="*.java, *.txt …" />
                      <!-- filter -->
                      <Label layoutX="364.0" layoutY="9.0" style="-fx-text-fill:#666;" text="Filters:" />
                      <Button fx:id="compareBtn" layoutX="220.0" onAction="#onCompare" style="-fx-font-weight:bold;" text="⚡ Compare ⚡" />
                      <ToggleButton fx:id="dirModeToggle" layoutX="667.0" layoutY="4.0" onAction="#onToggleDirMode" text="📁 Dirs" />
                  <Separator layoutX="603.0" layoutY="5.0" orientation="VERTICAL" prefHeight="31.0" prefWidth="16.0" />
               </children></Pane>
            </ToolBar>
        </VBox>
    </top>

    <!-- ═══ CENTER: left panel | action strip | right panel ═══ -->
    <center>
        <HBox VBox.vgrow="ALWAYS">

            <!-- ── LEFT panel ── -->
            <VBox fx:id="leftPanel" spacing="0" HBox.hgrow="ALWAYS">
                <padding><Insets bottom="4" left="4" right="2" top="4" /></padding>
                <HBox alignment="CENTER_LEFT" spacing="4">
                    <Label style="-fx-font-weight:bold;" text="Left:" />
                    <TextField fx:id="leftPathField" editable="false" promptText="file or directory…" HBox.hgrow="ALWAYS" />
                    <Button onAction="#onOpenLeft" prefWidth="30" text="…" />
                </HBox>
                <!-- column header -->
                <HBox fx:id="leftColumnHeader" spacing="0" style="-fx-background-color:linear-gradient(to bottom,#F8F8F8,#E8E8E8);                              -fx-border-color:#CCC;-fx-border-width:0 0 1 0;">
                    <padding><Insets bottom="3" left="4" right="4" top="3" /></padding>
                    <Label maxWidth="1.7976931348623157E308" style="-fx-font-weight:bold;-fx-font-size:12;" text="Name" HBox.hgrow="ALWAYS" />
                    <Label minWidth="90" prefWidth="90" style="-fx-font-weight:bold;-fx-font-size:12;-fx-alignment:CENTER_RIGHT;" text="Size" />
                    <Label minWidth="140" prefWidth="140" style="-fx-font-weight:bold;-fx-font-size:12;-fx-alignment:CENTER_RIGHT;" text="Modified" />
                </HBox>
                <ListView fx:id="leftListView" VBox.vgrow="ALWAYS" />
            </VBox>

            <!-- ── CENTER action strip ── -->
            <VBox fx:id="centerStrip" alignment="CENTER" maxWidth="80" minWidth="40" prefWidth="52" spacing="8" style="-fx-background-color:linear-gradient(to bottom, #e8e8e8, #d0d0d0);                          -fx-border-color:#bbb; -fx-border-width:0 1 0 1;                          -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.15),4,0,0,1);">
                <padding><Insets bottom="12" left="4" right="4" top="12" /></padding>

                <Button fx:id="copyRightBtn" onAction="#onCopyToRight" prefHeight="28" prefWidth="36" style="-fx-font-size:16; -fx-font-weight:bold;" text="→">
                    <tooltip><Tooltip text="Copy selected to right" /></tooltip>
                </Button>

                <Button fx:id="copyLeftBtn" onAction="#onCopyToLeft" prefHeight="28" prefWidth="36" style="-fx-font-size:16; -fx-font-weight:bold;" text="←">
                    <tooltip><Tooltip text="Copy selected to left" /></tooltip>
                </Button>

                <Separator prefWidth="30" />

                <Button fx:id="diffBtn" onAction="#onShowDiff" prefHeight="28" prefWidth="36" style="-fx-font-size:16; -fx-font-weight:bold; -fx-text-fill:#c00;" text="≠">
                    <tooltip><Tooltip text="Show differences" /></tooltip>
                </Button>

                <Button fx:id="equalBtn" onAction="#onShowEqual" prefHeight="28" prefWidth="36" style="-fx-font-size:16; -fx-font-weight:bold; -fx-text-fill:#070;" text="=">
                    <tooltip><Tooltip text="Show identical" /></tooltip>
                </Button>

                <Separator prefWidth="30" />

                <Button fx:id="deleteBtn" onAction="#onDeleteSelected" prefHeight="28" prefWidth="36" text="🗑">
                    <tooltip><Tooltip text="Delete selected" /></tooltip>
                </Button>
            </VBox>

            <!-- ── RIGHT panel ── -->
            <VBox fx:id="rightPanel" spacing="0" HBox.hgrow="ALWAYS">
                <padding><Insets bottom="4" left="2" right="4" top="4" /></padding>
                <HBox alignment="CENTER_LEFT" spacing="4">
                    <Label style="-fx-font-weight:bold;" text="Right:" />
                    <TextField fx:id="rightPathField" editable="false" promptText="file or directory…" HBox.hgrow="ALWAYS" />
                    <Button onAction="#onOpenRight" prefWidth="30" text="…" />
                </HBox>
                <!-- column header -->
                <HBox fx:id="rightColumnHeader" spacing="0" style="-fx-background-color:linear-gradient(to bottom,#F8F8F8,#E8E8E8);                              -fx-border-color:#CCC;-fx-border-width:0 0 1 0;">
                    <padding><Insets bottom="3" left="4" right="4" top="3" /></padding>
                    <Label maxWidth="1.7976931348623157E308" style="-fx-font-weight:bold;-fx-font-size:12;" text="Name" HBox.hgrow="ALWAYS" />
                    <Label minWidth="90" prefWidth="90" style="-fx-font-weight:bold;-fx-font-size:12;-fx-alignment:CENTER_RIGHT;" text="Size" />
                    <Label minWidth="140" prefWidth="140" style="-fx-font-weight:bold;-fx-font-size:12;-fx-alignment:CENTER_RIGHT;" text="Modified" />
                </HBox>
                <ListView fx:id="rightListView" VBox.vgrow="ALWAYS" />
            </VBox>

        </HBox>
    </center>

    <!-- ═══ BOTTOM: status bar ═══ -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color:#f0f0f0; -fx-border-color:#ccc; -fx-border-width:1 0 0 0;">
            <padding><Insets bottom="4" left="8" right="8" top="4" /></padding>
            <Label fx:id="statusLeft" style="-fx-text-fill:#666;" text="No file loaded" />
            <Pane HBox.hgrow="ALWAYS" />
            <Label fx:id="statusCenter" style="-fx-text-fill:#333; -fx-font-weight:bold;" text="" />
            <Pane HBox.hgrow="ALWAYS" />
            <Label fx:id="statusRight" style="-fx-text-fill:#666;" text="No file loaded" />
        </HBox>
    </bottom>

</BorderPane>