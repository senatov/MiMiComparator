# MiMiComparator — gitattributes
* text=auto eol=lf

# force LF for all text
*.java text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.fxml text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.properties text eol=lf
*.md text eol=lf
*.css text eol=lf
*.html text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.sh text eol=lf

# binary
*.jar binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.class binary
